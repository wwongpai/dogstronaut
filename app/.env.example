# Datadog
DD_API_KEY=your-datadog-api-key-here
DD_SITE=datadoghq.com

# RUM (set at frontend build time)
VITE_DD_RUM_APPLICATION_ID=your-rum-app-id-here
VITE_DD_RUM_CLIENT_TOKEN=your-rum-client-token-here

# Database
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_USER=postgres
POSTGRES_DB=dogstronaut

# Grafana admin password (only needed when running deploy-silo.sh)
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password-here
